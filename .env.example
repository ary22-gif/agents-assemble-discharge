# ── LLM ───────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here

# Model overrides (defaults shown — change to vertex_ai/... for Cloud Run)
ORCHESTRATOR_MODEL=gemini/gemini-2.5-pro
MEDRECON_MODEL=gemini/gemini-2.5-flash
CAREPLAN_MODEL=gemini/gemini-2.5-flash
FOLLOWUP_MODEL=gemini/gemini-2.5-flash

# ── URLs ───────────────────────────────────────────────────────────────────────
FHIR_BASE_URL=http://localhost:8000/fhir
A2A_BASE_URL=http://localhost

# Agent ports
ORCHESTRATOR_PORT=8001
MEDRECON_PORT=8002
CAREPLAN_PORT=8003
FOLLOWUP_PORT=8004

# ── Security ───────────────────────────────────────────────────────────────────
# API key required on all agent endpoints (X-API-Key header)
AGENT_API_KEY=change-me-before-deploy

# ── FHIR server ────────────────────────────────────────────────────────────────
FHIR_SERVER_PORT=8000

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_HOOK_RAW_OBJECTS=false

# ── A2A extension URI (must match Prompt Opinion workspace) ────────────────────
FHIR_EXTENSION_URI=https://app.promptopinion.ai/schemas/a2a/v1/fhir-context

# Suppress LiteLLM advisory warning (we use it intentionally for model flexibility)
ADK_SUPPRESS_GEMINI_LITELLM_WARNINGS=true
