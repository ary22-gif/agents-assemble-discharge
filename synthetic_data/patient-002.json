        "medicationCodeableConcept": {
          "coding": [{"system": "http://www.nlm.nih.gov/research/umls/rxnorm", "code": "1599543", "display": "Apixaban 5 MG Oral Tablet"}],
          "text": "Apixaban (Eliquis) 5 mg tablet"
        },
        "subject": {"reference": "Patient/patient-002"},
        "authoredOn": "2026-05-06",
        "requester": {"display": "Dr. Obi-Wan Kenobi, MD (Orthopedic Surgery)"},
        "dosageInstruction": [{"text": "Take 1 tablet by mouth twice daily for 35 days (DVT prophylaxis). Do not stop without physician guidance.", "timing": {"repeat": {"frequency": 2, "period": 1, "periodUnit": "d"}}}],
        "dispenseRequest": {"quantity": {"value": 70, "unit": "tablet"}},
        "note": [{"text": "DVT prophylaxis post-TKR. Duration: 35 days. Avoid NSAIDs and aspirin while on apixaban."}]
      }
    },
